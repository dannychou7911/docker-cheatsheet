<!DOCTYPE html>
<html lang="zh-Hant" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Docker Cheatsheet — 新手常用指令速查表</title>
  <meta name="description" content="專為 Docker 新手設計的常用指令速查表，包含容器、映像檔、Volume、Network 等分類指令與範例說明。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
          colors: {
            dock: {
              bg: '#0F172A',
              surface: '#1E293B',
              surface2: '#334155',
              accent: '#38BDF8',
              green: '#22C55E',
              yellow: '#FACC15',
              red: '#F87171',
              purple: '#A78BFA',
              orange: '#FB923C',
              text: '#F8FAFC',
              muted: '#94A3B8',
              dim: '#64748B',
            }
          }
        }
      }
    }
  </script>
  <style>
    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0F172A; }
    ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #475569; }

    /* Sidebar active link */
    .toc-link.active {
      color: #38BDF8;
      border-left-color: #38BDF8;
      background: rgba(56, 189, 248, 0.08);
    }

    /* Copy button feedback */
    .copy-btn.copied svg:first-child { display: none; }
    .copy-btn.copied svg:last-child { display: block; }
    .copy-btn svg:last-child { display: none; }

    /* Search highlight */
    mark {
      background: rgba(56, 189, 248, 0.25);
      color: #F8FAFC;
      border-radius: 2px;
      padding: 0 2px;
    }

    /* Mobile sidebar */
    #sidebar.open { transform: translateX(0); }

    /* Smooth code block */
    pre { tab-size: 2; }

    /* Tooltip */
    [data-tooltip]:hover::after {
      content: attr(data-tooltip);
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #1E293B;
      color: #F8FAFC;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 12px;
      white-space: nowrap;
      z-index: 50;
      border: 1px solid #334155;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body class="bg-dock-bg text-dock-text font-sans antialiased">

  <!-- Skip to content -->
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-dock-accent focus:text-dock-bg focus:px-4 focus:py-2 focus:rounded-lg focus:font-semibold">
    跳到主要內容
